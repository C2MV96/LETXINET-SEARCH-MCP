# LetXipu Search MCP v7 - Environment Variables
# NOTE: All variables can also be set in claude_desktop_config.json
#       under the "env" section. This .env file is only for local development.

PORT=4000

# ─── MinerU API (Document → Markdown) ─────────────────────────
# Get your FREE token at https://mineru.net → Login → API Management
# Without token = Flash mode (20 pages / 10MB per file, IP rate-limited)
# With token = Precision mode (200 pages / 200MB, 5000 pages/day)
# MINERU_API_KEY=your_token_here
# MINERU_API_URL=https://mineru.net/api/v4

# ─── Academic API Keys (optional, all sources work without keys) ─
# CORE_API_KEY=
# SCOPUS_API_KEY=
# S2_API_KEY=
